@page "/Contribuents/HabitatgesContribuent/{dni}/{cp}"
@model HabitatgesContribuentModel
@{
    ViewData["Title"] = "Habitatges del contribuent";

}

<h1>Codi Postal població @Model.Cp</h1>
<h1>Dni contribuent @Model.Dni</h1>

<h1>Habitatges del contribuent a @Model.Cp</h1>


@for(int i=0; i<Model.habitatgesXcp[Model.Cp][Model.Dni].Count; i++)
{
        <h2>@Model.habitatgesXcp[Model.Cp][Model.Dni][i]["adreca"]</h2>
}




