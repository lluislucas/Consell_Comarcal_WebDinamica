@page "/Contribuents/RebutsContribuent/{dni}/{cp}"
@model RebutContribuentModel
@{
    ViewData["Title"] = "Rebuts del contribuent";

}

<h1>Codi Postal població @Model.Cp</h1>
<h1>Dni contribuent @Model.Dni</h1>

<h2>Taxes del contribuent a @Model.Cp</h2>

<fieldset style="border: 2px solid black; padding: 10px;">
    <legend>Consell Comarcal -Taxa Especial sobre Habitatges</legend>
    <p><strong>Nom:</strong> @Model.habitatgesXcp[Model.Cp][Model.Dni][0]["nomContribuent"]<p/>
    <p><strong>Poblacio:</strong> @Model.habitatgesXcp[Model.Cp][Model.Dni][0]["poblacio"]<p/>
    <p>Cases:<p/>
    <p>Pisos:<p/>
    <p>Terreny:<p/>
    
    <h2>QUOTA:</h2>

</fieldset>


